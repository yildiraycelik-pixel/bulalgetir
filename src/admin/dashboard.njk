<script>
function cikisYap() {
    localStorage.removeItem('userLoggedIn');
    localStorage.removeItem('userIsAdmin');
    localStorage.removeItem('adminKullanici');
    window.location.href = '/';
}

// Giriş kontrolü ve tarih gösterimi
document.addEventListener('DOMContentLoaded', function() {
    const isAdmin = localStorage.getItem('userIsAdmin') === 'true';
    if (!isAdmin) {
        window.location.href = '/admin/';
    }
    
    // Son giriş tarihini göster
    const now = new Date();
    const options = { day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' };
    document.getElementById('son-giris').textContent = now.toLocaleDateString('tr-TR', options);
});

// Admin giriş fonksiyonu (admin.njk'de kullanmak için)
window.adminGiris = function() {
    const username = document.getElementById('username').value;
    const password = document.getElementById('password').value;
    
    if (username === 'admin' && password === 'admin123') {
        localStorage.setItem('userLoggedIn', 'true');
        localStorage.setItem('userIsAdmin', 'true');
        localStorage.setItem('adminKullanici', username);
        alert('✅ Giriş başarılı! Yönetici paneline yönlendiriliyorsunuz.');
        window.location.href = '/admin/dashboard';
    } else {
        alert('❌ Hatalı kullanıcı adı veya şifre!');
    }
};
</script>
