---
layout: base.njk
title: Ana Sayfa
description: BulalGetir - İkinci el malzeme satışı, elektromekanik proje tasarım ve uygulama platformu
---

<div class="anasayfa">
    <!-- Hero Banner with 5+5 Images - Kompakt -->
    <section class="hero" style="margin-bottom: 5px; padding: 15px 0;">
        <div class="container">
            <div style="display: flex; align-items: center; justify-content: space-between; gap: 15px;">
                
                <!-- SOL GÖRSELLER (5 adet) -->
                <div style="display: flex; gap: 6px; flex: 1; justify-content: flex-start;">
                    <div class="hero-gallery">
                        <img src="/assets/images/16A-wotomat.webp" alt="Elektrik">
                    </div>
                    <div class="hero-gallery">
                        <img src="/assets/images/acil-aydinlatma.webp" alt="Aydınlatma">
                    </div>
                    <div class="hero-gallery">
                        <img src="/assets/images/step-motor.webp" alt="Step Motor">
                    </div>
                    <div class="hero-gallery">
                        <img src="/assets/images/servo-motor.webp" alt="Servo Motor">
                    </div>
                    <div class="hero-gallery">
                        <img src="/assets/images/aku-jel.webp" alt="Akü">
                    </div>
                </div>
                
                <!-- ORTA - SADECE İKİNCİL METİN VE BUTONLAR -->
                <div style="flex: 2; text-align: center;">
                    <p style="font-size: 15px; margin-bottom: 10px; opacity: 0.9;">İkinci el malzeme, proje tasarım ve uygulama hizmetleri</p>
                    <div style="display: flex; gap: 12px; justify-content: center;">
                        <a href="/kategoriler/" class="btn-alisveris" style="background: #e6b17e; color: #1e3f1e; padding: 6px 20px; border-radius: 30px; text-decoration: none; font-weight: 500; font-size: 14px;">Alışverişe Başla</a>
                        <a href="/projeler/" class="btn-projeler" style="background: transparent; color: white; padding: 6px 20px; border-radius: 30px; text-decoration: none; border: 2px solid white; font-weight: 500; font-size: 14px;">Projelerimiz</a>
                    </div>
                </div>
                
                <!-- SAĞ GÖRSELLER (5 adet) -->
                <div style="display: flex; gap: 6px; flex: 1; justify-content: flex-end;">
                    <div class="hero-gallery">
                        <img src="/assets/images/380v-1hp-ac-general-electric.webp" alt="AC Motor">
                    </div>
                    <div class="hero-gallery">
                        <img src="/assets/images/Ac-servo-motor-ve-surucusu.webp" alt="Servo Motor">
                    </div>
                    <div class="hero-gallery">
                        <img src="/assets/images/agir-hizmet-mengenesi.webp" alt="Mengene">
                    </div>
                    <div class="hero-gallery">
                        <img src="/assets/images/solar-panel.webp" alt="Solar Panel">
                    </div>
                    <div class="hero-gallery">
                        <img src="/assets/images/mini-pc-raspberry-pi.webp" alt="Raspberry Pi">
                    </div>
                </div>
            </div>
        </div>
    </section>
    
    <!-- Kategoriler - Yaprak formunda butonlar -->
    <section class="ana-kategoriler" style="padding: 15px 0;">
        <div class="container">
            <div style="display: flex; flex-wrap: wrap; gap: 10px; justify-content: center;">
                {% for kategori in kategoriler.kategoriler %}
                <a href="/{{ kategori.slug }}/" class="kategori-buton">
                    {{ kategori.adi }}
                </a>
                {% endfor %}
            </div>
        </div>
    </section>
    
    <!-- Hizmetler - Buton formatında -->
    <section class="hizmetler" style="margin-top: 5px;">
        <div class="container">
            <div style="display: flex; flex-wrap: wrap; gap: 10px; justify-content: center;">
                <a href="/ikinci-el/" class="kategori-buton">İkinci El Malzeme</a>
                <a href="/proje-tasarim/" class="kategori-buton">Proje Tasarım</a>
                <a href="/uygulama-atolye/" class="kategori-buton">Uygulama Atölye</a>
                <a href="/laboratuvar-test/" class="kategori-buton">Laboratuvar Test</a>
            </div>
        </div>
    </section>
    
    <!-- Son Eklenen Ürünler -->
    <section class="son-urunler">
        <div class="container">
            <h2>Son Eklenen Ürünler</h2>
            <div class="urun-grid">
                {% for urun in urunler.urunler %}
                <div class="urun-kart">
                    <div class="urun-gorsel">
                        <img src="{{ urun.gorsel }}" alt="{{ urun.adi }}" loading="lazy">
                        {% if urun.durum == "Sıfır" %}
                        <span class="urun-badge yeni">Yeni</span>
                        {% else %}
                        <span class="urun-badge ikinci-el">İkinci El</span>
                        {% endif %}
                    </div>
                    <div class="urun-bilgi">
                        <h3><a href="#">{{ urun.adi }}</a></h3>
                        <p class="urun-marka">{{ urun.marka }} {{ urun.model }}</p>
                        <p class="urun-fiyat">{{ urun.fiyat }} TL</p>
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
    </section>
    
    <!-- İstatistikler -->
    <div class="istatistik-row">
        <div class="istatistik-kutu">
            <div class="sayi">500+</div>
            <div>Ürün Çeşidi</div>
        </div>
        <div class="istatistik-kutu">
            <div class="sayi">100+</div>
            <div>Mutlu Müşteri</div>
        </div>
        <div class="istatistik-kutu">
            <div class="sayi">7/24</div>
            <div>Destek</div>
        </div>
    </div>
    
    <!-- Güven Rozetleri -->
    <div class="guven-rozetleri">
        <div><i class="fas fa-truck"></i> <span>Hızlı Teslimat</span></div>
        <div><i class="fas fa-shield-alt"></i> <span>Güvenli Alışveriş</span></div>
        <div><i class="fas fa-undo-alt"></i> <span>Kolay İade</span></div>
        <div><i class="fas fa-headset"></i> <span>7/24 Destek</span></div>
    </div>
    
    <!-- Günün Fırsatı -->
    <div class="gunun-firsati">
        <h3>Günün Fırsatı</h3>
        <p>Seçili ürünlerde %20'ye varan indirim!</p>
        <a href="/firsatlar">Hemen İncele</a>
    </div>
</div>

<style>
/* ===== TEMEL STİLLER ===== */
.hero {
    margin-bottom: 5px !important;
    background: linear-gradient(135deg, #2c5f2d 0%, #1e3f1e 100%);
    color: white;
    min-height: auto !important;
}

.hero-gallery {
    width: 55px;
    height: 55px;
    border-radius: 8px;
    overflow: hidden;
    transition: all 0.3s ease;
    border: 2px solid rgba(255,255,255,0.2);
}

.hero-gallery img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: all 0.3s ease;
}

.hero-gallery:hover {
    transform: scale(1.15);
    border-color: #e6b17e;
    box-shadow: 0 8px 20px rgba(0,0,0,0.3);
    z-index: 10;
}

.kategori-buton {
    display: inline-block;
    padding: 5px 16px;
    background: #2c5f2d;
