/* ===== RESPONSIVE ===== */
@media (max-width: 992px) {
    .urun-grid {
        grid-template-columns: repeat(3, 1fr) !important;
    }
}

@media (max-width: 768px) {
    .urun-grid {
        grid-template-columns: repeat(2, 1fr) !important;
    }
    
    .urun-gorsel {
        height: 130px !important;
