    border-radius: 40px;
    box-shadow: 0 3px 10px rgba(0,0,0,0.05);
}

.guven-rozetleri > div {
    display: flex;
    align-items: center;
    gap: 8px;
}

.guven-rozetleri i {
    font-size: 22px;
    color: #e6b17e;
}

/* ===== GÜNÜN FIRSATI ===== */
.gunun-firsati {
    background: linear-gradient(135deg, #2c5f2d10, #e6b17e20);
    border-radius: 15px;
    padding: 40px;
    margin: 40px 0;
    text-align: center;
    border: 2px solid #e6b17e;
}

.gunun-firsati h3 {
    color: #2c5f2d;
    font-size: 28px;
    margin-bottom: 10px;
}

.gunun-firsati p {
    font-size: 16px;
    margin-bottom: 20px;
}

.gunun-firsati a {
    display: inline-block;
    background: #e6b17e;
    color: #1e3f1e;
    padding: 12px 40px;
    border-radius: 40px;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.3s;
}

.gunun-firsati a:hover {
