---
layout: base.njk
title: Giriş Yap
description: BulalGetir hesabınıza giriş yapın
---

<div class="auth-container">
    <div class="auth-box">
        <h1>Giriş Yap</h1>
        
        <form action="/giris-yap" method="POST" class="auth-form">
            <div class="form-group">
                <label for="email">E-posta</label>
                <input type="email" id="email" name="email" required>
            </div>
            
            <div class="form-group">
                <label for="password">Şifre</label>
                <input type="password" id="password" name="password" required>
            </div>
            
            <div class="form-group remember-me">
                <label>
                    <input type="checkbox" name="remember"> Beni Hatırla
                </label>
                <a href="/sifremi-unuttum" class="forgot-password">Şifremi Unuttum</a>
            </div>
            
            <button type="submit" class="auth-btn">Giriş Yap</button>
        </form>
        
        <div class="auth-footer">
            <p>Hesabınız yok mu? <a href="/kayit-ol">Kayıt Ol</a></p>
        </div>
    </div>
</div>
